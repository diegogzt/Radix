############################################################
# Supabase Self-Hosted — Environment Variables
# Copy to .env and fill in real values before first run.
#
# Generate ANON_KEY and SERVICE_ROLE_KEY at:
#   https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# or use: https://jwt.io  (algorithm: HS256, secret = JWT_SECRET)
#
# Payload for ANON_KEY:
#   { "role": "anon", "iss": "supabase", "iat": ..., "exp": ... }
# Payload for SERVICE_ROLE_KEY:
#   { "role": "service_role", "iss": "supabase", "iat": ..., "exp": ... }
############################################################

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-postgres-password
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ── JWT ────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-chars
JWT_EXPIRY=3600

# ── API Keys (JWTs signed with JWT_SECRET) ─────────────────
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_WITH_REAL_ANON_JWT
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_WITH_REAL_SERVICE_ROLE_JWT

# ── URLs ───────────────────────────────────────────────────
# Public URL of the Kong API gateway (what clients use)
SUPABASE_PUBLIC_URL=http://your-vps-ip:8000
# Your frontend app URL (for auth redirects)
SITE_URL=http://your-vps-ip:4321
API_EXTERNAL_URL=http://your-vps-ip:8000
ADDITIONAL_REDIRECT_URLS=

# ── Studio Dashboard ───────────────────────────────────────
STUDIO_PORT=3001
STUDIO_DEFAULT_ORGANIZATION=RADIX
STUDIO_DEFAULT_PROJECT=radix-medical
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-strong-password

# ── SMTP (optional — for email auth) ───────────────────────
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=RADIX Medical

# ── Auth URL paths ─────────────────────────────────────────
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# ── PostgREST ──────────────────────────────────────────────
PGRST_DB_SCHEMAS=public,storage

# ── Realtime ───────────────────────────────────────────────
SECRET_KEY_BASE=your-realtime-secret-key-base-at-least-64-chars-long-replace-this

# ── Misc ───────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
IMGPROXY_ENABLE_WEBP_DETECTION=true
