###############################################################################
# RADIX — Variables de entorno del stack completo
# Copia a .env y rellena con valores reales.
#
# Guía de fases:
#
#   Fase 1 (IP directa / dev):
#     PUBLIC_SUPABASE_URL=http://10.0.0.5:8000
#     SUPABASE_URL=http://10.0.0.5:8000
#     PUBLIC_API_URL=http://10.0.0.5:8001
#     ALLOWED_ORIGINS=http://10.0.0.5:4321
#     FRONTEND_URL=http://10.0.0.5:4321
#
#   Fase 2 (dominio temporal):
#     PUBLIC_SUPABASE_URL=https://bd-staging.radix-bcn.es
#     SUPABASE_URL=https://bd-staging.radix-bcn.es
#     PUBLIC_API_URL=https://api-staging.radix-bcn.es
#     ALLOWED_ORIGINS=https://app-staging.radix-bcn.es
#     FRONTEND_URL=https://app-staging.radix-bcn.es
#
#   Fase 3 (producción):
#     PUBLIC_SUPABASE_URL=https://bd.radix-bcn.es
#     SUPABASE_URL=https://bd.radix-bcn.es
#     PUBLIC_API_URL=https://api.radix-bcn.es
#     ALLOWED_ORIGINS=https://app.radix-bcn.es
#     FRONTEND_URL=https://app.radix-bcn.es
#
###############################################################################

# ── Supabase / Base de datos (frontend — baked en build) ──────────────────────
PUBLIC_SUPABASE_URL=http://your-vps-ip:8000
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── FastAPI Backend (frontend — baked en build) ───────────────────────────────
PUBLIC_API_URL=http://your-vps-ip:8001

# ── Puertos expuestos ─────────────────────────────────────────────────────────
FRONTEND_PORT=4321
BACKEND_PORT=8001

# ── Backend — Supabase (server-side, no se hornea en build) ───────────────────
SUPABASE_URL=http://your-vps-ip:8000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Backend — CORS (lista separada por comas) ─────────────────────────────────
ALLOWED_ORIGINS=http://your-vps-ip:4321
FRONTEND_URL=http://your-vps-ip:4321
