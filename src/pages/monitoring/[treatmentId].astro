---
import MainLayout from '@layouts/MainLayout.astro';
import LiveMetricsPanel from '@components/monitoring/LiveMetricsPanel';
import { getServerClient } from '@lib/supabase';
import { getTreatmentById, getHealthMetrics } from '@lib/queries';

const { treatmentId } = Astro.params;
const supabase = getServerClient(Astro);

const treatment = await getTreatmentById(supabase, Number(treatmentId));

if (!treatment) {
  return Astro.redirect('/dashboard');
}

const metrics = await getHealthMetrics(supabase, treatment.id, 100);
const patientName = treatment.Patient?.name ?? 'Paciente';
---

<MainLayout
  title={`Monitoreo: ${patientName}`}
  subtitle={`${treatment.Radioisotope?.name ?? 'Isotopo'} - Tratamiento #${treatment.id}`}
>
  <LiveMetricsPanel
    client:load
    treatmentId={treatment.id}
    initialMetrics={metrics}
    treatment={treatment}
  />
</MainLayout>
