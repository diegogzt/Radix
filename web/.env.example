# ── Supabase / Base de datos ───────────────────────────────────────────────────
# URL pública de Kong (self-hosted) o del proyecto Supabase Cloud.
# ⚠️  Este valor se hornea en el bundle del cliente en tiempo de build.
#     Para cambiarlo hay que reconstruir la imagen Docker.
#
# Fase 1 — IP directa:    PUBLIC_SUPABASE_URL=http://192.168.1.10:8000
# Fase 2 — Dominio temp:  PUBLIC_SUPABASE_URL=https://bd-staging.radix-bcn.es
# Fase 3 — Producción:    PUBLIC_SUPABASE_URL=https://bd.radix-bcn.es
#
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── FastAPI Backend ─────────────────────────────────────────────────────────────
# URL del servidor backend FastAPI.
# ⚠️  También se hornea en el bundle del cliente si se usa en islas React.
#
# Fase 1 — IP directa:    PUBLIC_API_URL=http://192.168.1.10:8001
# Fase 2 — Dominio temp:  PUBLIC_API_URL=https://api-staging.radix-bcn.es
# Fase 3 — Producción:    PUBLIC_API_URL=https://api.radix-bcn.es
#
PUBLIC_API_URL=http://localhost:8000
