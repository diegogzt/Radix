---
import MainLayout from '@layouts/MainLayout.astro';
import TreatmentCard from '@components/dashboard/TreatmentCard.astro';
import { getActiveTreatments, getUnresolvedAlerts, getPatients } from '@lib/queries';

let treatments = [];
let alertCount = 0;
let patientCount = 0;
let errorMsg = '';

try {
  treatments = await getActiveTreatments();
  const alerts = await getUnresolvedAlerts();
  alertCount = alerts.length;
  const patients = await getPatients();
  patientCount = patients.length;
} catch (err) {
  errorMsg = err instanceof Error ? err.message : 'Error al cargar datos';
}

const hour = new Date().getHours();
let greeting = 'Buenos días';
if (hour >= 12 && hour < 19) greeting = 'Buenas tardes';
else if (hour >= 19) greeting = 'Buenas noches';
---

<MainLayout title="Dashboard" subtitle="Vista general de la unidad de radiofarmacia">
  
  <div class="mb-8">
    <h2 class="text-2xl font-bold tracking-tight text-gray-900">{greeting}, Doctor</h2>
    <p class="text-gray-500">Aquí está el resumen de sus tratamientos activos.</p>
  </div>

  {errorMsg && (
    <div class="mb-6 rounded-xl border border-red-200/60 bg-red-50/80 px-4 py-3 text-sm text-red-700 backdrop-blur-sm">
      {errorMsg}
    </div>
  )}

  <!-- Stats bar -->
  <div class="mb-10 grid grid-cols-1 gap-5 sm:grid-cols-3">
    <!-- Active Treatments Stat -->
    <div class="card relative overflow-hidden p-5 border-l-4 border-l-radix-500">
      <div class="absolute right-0 top-0 -mt-4 -mr-4 h-24 w-24 rounded-full bg-radix-50 opacity-50 blur-xl"></div>
      <div class="relative flex items-center gap-4">
        <div class="stat-icon bg-gradient-to-br from-radix-100 to-radix-200 shadow-sm ring-1 ring-radix-200/50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-radix-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">Tratamientos</p>
          <div class="flex items-baseline gap-2">
            <p class="text-3xl font-bold tracking-tight text-gray-900">{treatments.length}</p>
            <span class="text-xs font-medium text-green-600">Activos</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Patients Stat -->
    <div class="card relative overflow-hidden p-5 border-l-4 border-l-blue-500">
      <div class="absolute right-0 top-0 -mt-4 -mr-4 h-24 w-24 rounded-full bg-blue-50 opacity-50 blur-xl"></div>
      <div class="relative flex items-center gap-4">
        <div class="stat-icon bg-gradient-to-br from-blue-100 to-blue-200 shadow-sm ring-1 ring-blue-200/50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">Pacientes</p>
          <p class="text-3xl font-bold tracking-tight text-gray-900">{patientCount}</p>
        </div>
      </div>
    </div>

    <!-- Alerts Stat -->
    <div class:list={['card relative overflow-hidden p-5 border-l-4', alertCount > 0 ? 'border-l-red-500' : 'border-l-emerald-500']}>
      <div class:list={['absolute right-0 top-0 -mt-4 -mr-4 h-24 w-24 rounded-full opacity-50 blur-xl', alertCount > 0 ? 'bg-red-50' : 'bg-emerald-50']}></div>
      <div class="relative flex items-center gap-4">
        <div class:list={[
          'stat-icon shadow-sm ring-1',
          alertCount > 0 ? 'bg-gradient-to-br from-red-100 to-red-200 ring-red-200/50' : 'bg-gradient-to-br from-emerald-100 to-emerald-200 ring-emerald-200/50',
        ]}>
          <svg xmlns="http://www.w3.org/2000/svg" class:list={['h-5 w-5', alertCount > 0 ? 'text-red-600' : 'text-emerald-600']} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            {alertCount > 0 ? (
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0" />
            ) : (
              <polyline points="20 6 9 17 4 12" />
            )}
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">Alertas</p>
          <div class="flex items-baseline gap-2">
            <p class:list={['text-3xl font-bold tracking-tight', alertCount > 0 ? 'text-red-600' : 'text-gray-900']}>
              {alertCount}
            </p>
            <span class="text-xs font-medium text-gray-500">{alertCount === 1 ? 'Pendiente' : 'Pendientes'}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mb-4 flex items-center justify-between">
    <h3 class="text-lg font-bold text-gray-900">Monitoreo de Pacientes</h3>
    <a href="/treatments/new" class="text-sm font-semibold text-radix-600 hover:text-radix-700">Ver historial →</a>
  </div>

  <!-- Treatment cards grid -->
  {treatments.length === 0 && !errorMsg ? (
    <div class="card flex flex-col items-center justify-center border-dashed px-4 py-20 text-center">
      <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-gray-50 ring-1 ring-gray-200/50">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="3" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-gray-900">No hay tratamientos activos</h3>
      <p class="mt-2 text-sm text-gray-500 max-w-sm">Los pacientes a los que se les asigne un tratamiento activo aparecerán aquí para su monitoreo.</p>
      <a href="/treatments/new" class="btn-primary mt-6">
        Crear Tratamiento
      </a>
    </div>
  ) : (
    <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {treatments.map((treatment, i) => (
        <div class={`animate-slide-up stagger-${i % 4 + 1}`}>
          <TreatmentCard treatment={treatment} />
        </div>
      ))}
    </div>
  )}
</MainLayout>
