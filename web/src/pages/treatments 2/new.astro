---
import MainLayout from '@layouts/MainLayout.astro';
import TreatmentForm from '@components/treatments/TreatmentForm';
import { getServerClient } from '@lib/supabase';
import {
  getPatients,
  getRadioisotopes,
  getUnitCatalog,
  getAvailableWatches,
  getFacultatiu,
} from '@lib/queries';

const supabase = getServerClient(Astro);

const [patients, radioisotopes, units, watches, doctors] = await Promise.all([
  getPatients(supabase),
  getRadioisotopes(supabase),
  getUnitCatalog(supabase),
  getAvailableWatches(supabase),
  getFacultatiu(supabase),
]);
---

<MainLayout title="Nuevo Tratamiento" subtitle="Configurar terapia de aislamiento domiciliario">
  <TreatmentForm
    client:load
    patients={patients}
    radioisotopes={radioisotopes}
    units={units}
    watches={watches}
    doctors={doctors}
  />
</MainLayout>
